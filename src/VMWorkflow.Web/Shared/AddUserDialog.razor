@using VMWorkflow.Web.Models
@using VMWorkflow.Web.Services
@inject IApiClient ApiClient
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField T="string" Label="Username" @bind-Value="_model.Username" Required="true" RequiredError="Username is required" />
            <MudTextField T="string" Label="Display Name" @bind-Value="_model.DisplayName" Required="true" RequiredError="Display name is required" />
            <MudTextField T="string" Label="Email" @bind-Value="_model.Email" Required="true" RequiredError="Email is required" InputType="InputType.Email" />
            <MudSelect T="string" Label="Role" @bind-Value="_model.Role" Required="true" RequiredError="Role is required">
                <MudSelectItem Value="@("Requester")">Requester</MudSelectItem>
                <MudSelectItem Value="@("NOCEngineer")">NOC Engineer</MudSelectItem>
                <MudSelectItem Value="@("SOCAnalyst")">SOC Analyst</MudSelectItem>
                <MudSelectItem Value="@("PlatformAdmin")">Platform Admin</MudSelectItem>
                <MudSelectItem Value="@("SysAdmin")">Sys Admin</MudSelectItem>
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@_submitting">
            @if (_submitting)
            {
                <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
            }
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;

    private CreateUserModel _model = new();
    private bool _submitting;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_model.Username) ||
            string.IsNullOrWhiteSpace(_model.DisplayName) ||
            string.IsNullOrWhiteSpace(_model.Email) ||
            string.IsNullOrWhiteSpace(_model.Role))
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Warning);
            return;
        }

        _submitting = true;
        try
        {
            await ApiClient.CreateUserAsync(_model);
            Snackbar.Add($"User '{_model.Username}' created successfully.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Conflict)
        {
            Snackbar.Add("Username already exists.", Severity.Error);
        }
        catch
        {
            Snackbar.Add("Failed to create user.", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }
}
