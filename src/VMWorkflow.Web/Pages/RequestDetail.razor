    private static string? HostnameValidator(string val)
    {
        if (string.IsNullOrWhiteSpace(val)) return "Hostname is required.";
        if (val.Length > 200) return "Hostname must be 200 characters or less.";
        if (!System.Text.RegularExpressions.Regex.IsMatch(val, @"^[a-zA-Z0-9][a-zA-Z0-9\-\.]*$"))
            return "Hostname can only contain letters, numbers, hyphens and dots.";
        return null;
    }

