    private static string? IPAddressValidator(string val)
    {
        if (string.IsNullOrWhiteSpace(val)) return null;
        if (!System.Net.IPAddress.TryParse(val, out _)) return "Enter a valid IP address (e.g. 192.168.1.1).";
        return null;
    }

    private static string? SubnetMaskValidator(string val)
    {
        if (string.IsNullOrWhiteSpace(val)) return null;
        if (!System.Net.IPAddress.TryParse(val, out _)) return "Enter a valid subnet mask (e.g. 255.255.255.0).";
        return null;
    }

    private static string? PortValidator(string val)
    {
        if (string.IsNullOrWhiteSpace(val)) return null;
        if (!int.TryParse(val, out var port) || port < 1 || port > 65535) return "Enter a valid port number (1-65535).";
        return null;
    }

    private static string? OptionalIPValidator(string val)
    {
        if (string.IsNullOrWhiteSpace(val)) return null;
        if (!System.Net.IPAddress.TryParse(val, out _)) return "Enter a valid IP address.";
        return null;
    }

    private static string? OptionalPortValidator(string val)
    {
