@page "/request/{RequestId:guid}"
@attribute [Authorize]
@inject IApiClient Api
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using System.Security.Claims

<PageTitle>Request Detail</PageTitle>

<div class="page-content">
@if (isLoading)
{
    <MudStack Spacing="4">
        <div class="shimmer" style="height: 40px; width: 300px;"></div>
        <div class="shimmer" style="height: 80px;"></div>
        <div class="shimmer" style="height: 200px;"></div>
    </MudStack>
}
else if (request == null)
{
    <MudPaper Class="premium-card pa-8 text-center" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default);">
        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Style="opacity: 0.3;" />
        <MudText Typo="Typo.h6" Class="mt-3">Request not found</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/" Class="mt-3" Style="border-radius: 12px;">
            Back to Dashboard
        </MudButton>
    </MudPaper>
}
else
{
    @* Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/" Variant="Variant.Outlined" Size="Size.Small"
                           Style="border-radius: 10px;" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.h5" Style="font-weight: 700;">@request.ObjectSlug</MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@request.ApplicationName</MudText>
            </MudStack>
            <MudChip T="string" Color="@GetStatusColor(request.Status)" Variant="Variant.Filled" Size="Size.Medium"
                     Style="border-radius: 10px; font-weight: 600;">
                <span class="pulse-dot @GetPulseClass(request.Status)" style="margin-right: 6px;"></span>
                @FormatStatus(request.Status)
            </MudChip>
        </MudStack>
        @if (CanSendBack(request.Status) && !WasSentBack)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Dark" StartIcon="@Icons.Material.Filled.Undo"
                OnClick="@(() => showSendBack = !showSendBack)" Style="border-radius: 12px; text-transform: none;">
                Send Back
            </MudButton>
        }
    </MudStack>

    @* Workflow Stepper — Premium *@
    <MudPaper Elevation="0" Class="premium-card pa-0 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
        <div class="workflow-stepper">
            @for (int i = 0; i < workflowSteps.Length; i++)
            {
                var step = workflowSteps[i];
                var isCurrent = step.Status == request.Status || (step.Status == "PendingNOC" && request.Status == "PendingSOC");
                var isPast = GetStepIndex(request.Status) > GetStepIndex(step.Status);

                if (i > 0)
                {
                    <div class="step-connector @(isPast ? "connector-done" : isCurrent ? "connector-active" : "")"></div>
                }

                <div class="workflow-step @(isPast ? "step-done" : isCurrent ? "step-current" : "")">
                    <div class="step-circle @(isPast ? "step-done" : isCurrent ? "step-current" : "step-future")">
                        @if (isPast)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="color: white;" />
                        }
                        else
                        {
                            @step.Number
                        }
                    </div>
                    <span class="step-label">@step.Label</span>
                </div>
            }
        </div>
    </MudPaper>

    @* Send Back Panel *@
    @if (showSendBack)
    {
        <MudPaper Elevation="0" Class="section-card action-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Undo" Color="Color.Dark" />
                <MudText Typo="Typo.h6">Send Back to Previous Step</MudText>
            </MudStack>
            <MudTextField @bind-Value="sendBackComments" Label="Reason (required)" Required="true"
                Lines="3" Variant="Variant.Outlined" Class="mb-3" />
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Dark" OnClick="HandleSendBack"
                    Disabled="@(isBusy || string.IsNullOrWhiteSpace(sendBackComments))"
                    Style="border-radius: 12px; text-transform: none;">
                    @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Send Back
                </MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="@(() => showSendBack = false)"
                    Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
            </MudStack>
        </MudPaper>
    }

    @* Error *@
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => errorMessage = null)"
                  Style="border-radius: 12px;">@errorMessage</MudAlert>
    }

    <MudGrid>
        @* Left Column *@
        <MudItem xs="12" md="8">
            <div class="stagger-in">
                @* Application Info *@
                <MudPaper Elevation="0" Class="section-card gradient-border-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                        <MudAvatar Size="Size.Small" Style="background: var(--gradient-primary);">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="color: white;" />
                        </MudAvatar>
                        <MudText Typo="Typo.h6">Application Info</MudText>
                    </MudStack>
                    <MudSimpleTable Dense="true" Hover="true" Style="border-radius: 12px;">
                        <tbody>
                            <tr><td style="width:200px"><strong>Application Name</strong></td><td>@request.ApplicationName</td></tr>
                            <tr><td><strong>Environment</strong></td><td>@request.Environment</td></tr>
                            <tr><td><strong>Language</strong></td><td>@(request.ProgrammingLanguage ?? "—")</td></tr>
                            <tr><td><strong>Framework</strong></td><td>@(request.Framework ?? "—")</td></tr>
                            <tr><td><strong>Purpose</strong></td><td>@(request.Purpose ?? "—")</td></tr>
                            <tr><td><strong>Expected Concurrent User Count</strong></td><td>@(request.ExpectedUsers?.ToString() ?? "—")</td></tr>
                            <tr><td><strong>DBMS</strong></td><td>@(request.DBMS ?? "—")</td></tr>
                            <tr><td><strong>Git Repo</strong></td><td>@(request.GitRepoLink ?? "—")</td></tr>
                            <tr><td><strong>Access Group</strong></td><td>@(request.AccessGroup ?? "—")</td></tr>
                            <tr><td><strong>SLA</strong></td><td>@request.SLA</td></tr>
                            <tr><td><strong>FQDN Suggestion</strong></td><td>@(request.FQDNSuggestion ?? "—")</td></tr>
                            <tr><td><strong>Auth Method</strong></td><td>@(request.AuthenticationMethod ?? "—")</td></tr>
                            <tr><td><strong>Created By</strong></td><td>@request.CreatedBy</td></tr>
                            <tr><td><strong>Created At</strong></td><td>@request.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</td></tr>
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>

                @* Draft → Edit / Submit *@
                @if (request.Status == "Draft")
                {
                    @if (isEditingDraft)
                    {
                        <MudPaper Elevation="0" Class="section-card action-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                                <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #ffa726, #ff7043);">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Style="color: white;" />
                                </MudAvatar>
                                <MudText Typo="Typo.h6">Edit Draft</MudText>
                            </MudStack>
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="editModel.ApplicationName" Label="Application Name" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="editModel.ProgrammingLanguage" Label="Language" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="editModel.Framework" Label="Framework" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudNumericField @bind-Value="editModel.ExpectedUsers" Label="Expected Concurrent User Count" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="editModel.Purpose" Label="Purpose" Variant="Variant.Outlined" Lines="2" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudSelect @bind-Value="editModel.DBMS" Label="DBMS" Variant="Variant.Outlined" T="string" Clearable="true">
                                        @foreach (var opt in _dbmsList)
                                        {
                                            <MudSelectItem Value="@opt.Value">@opt.Value</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="editModel.GitRepoLink" Label="Git Repo" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="editModel.AccessGroup" Label="Access Group" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudSelect @bind-Value="editModel.SLA" Label="SLA" Variant="Variant.Outlined">
                                        @foreach (var opt in _slaLevels)
                                        {
                                            <MudSelectItem Value="@opt.Value">@opt.Value</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="editModel.FQDNSuggestion" Label="FQDN Suggestion" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="editModel.AuthenticationMethod" Label="Auth Method" Variant="Variant.Outlined" />
                                </MudItem>
                            </MudGrid>
                            <MudStack Row="true" Spacing="2" Class="mt-4">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleSaveDraft" Disabled="@isBusy"
                                           StartIcon="@Icons.Material.Filled.Save" Style="border-radius: 12px; text-transform: none;">
                                    @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                    Save Changes
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" OnClick="@(() => isEditingDraft = false)"
                                           Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
                            </MudStack>
                        </MudPaper>
                    }
                    else
                    {
                        <MudPaper Elevation="0" Class="section-card action-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                                <MudAvatar Size="Size.Small" Style="background: var(--gradient-primary);">
                                    <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Small" Style="color: white;" />
                                </MudAvatar>
                                <MudText Typo="Typo.h6">Submit Request</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
                                Submit this request to send it to the SysAdmin for review, or edit the draft first.
                            </MudText>
                            <MudStack Row="true" Spacing="2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleSubmit" Disabled="@isBusy"
                                           StartIcon="@Icons.Material.Filled.Send" Style="border-radius: 12px; text-transform: none;">
                                    @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                    Submit Request
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="StartEditDraft"
                                           StartIcon="@Icons.Material.Filled.Edit" Style="border-radius: 12px; text-transform: none;">
                                    Edit Draft
                                </MudButton>
                            </MudStack>
                        </MudPaper>
                    }
                }

                @* SysAdmin Form *@
                @if (CanSeeSection(1) && request.Status == "PendingSysAdmin")
                {
                    <MudPaper Elevation="0" Class="section-card action-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #4facfe, #00f2fe);">
                                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Small" Style="color: white;" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">SysAdmin Details</MudText>
                        </MudStack>
                        <MudForm @ref="sysAdminForm">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudSelect @bind-Value="sysAdminModel.SensitivityLevel" Label="Sensitivity Level" Variant="Variant.Outlined" Required="true" RequiredError="Sensitivity Level is required.">
                                    @foreach (var opt in _sensitivityLevels)
                                    {
                                        <MudSelectItem Value="@opt.Value">@opt.Value</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect @bind-Value="sysAdminModel.WebServer" Label="Web Server" Variant="Variant.Outlined" Required="true" RequiredError="Web Server is required.">
                                    @foreach (var opt in _webServers)
                                    {
                                        <MudSelectItem Value="@opt.Value">@opt.Value</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="sysAdminModel.Hostname" Label="Hostname" Variant="Variant.Outlined" Required="true" Validation="@(new Func<string, string?>(HostnameValidator))" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle2" Class="mb-1" Style="font-weight: 600;">Database</MudText>
                                <MudRadioGroup @bind-Value="sysAdminModel.DatabaseNameType" T="string">
                                    <MudRadio Value="@("new")" Color="Color.Primary" Dense="true">New Database</MudRadio>
                                    <MudRadio Value="@("existing")" Color="Color.Primary" Dense="true">Existing Database</MudRadio>
                                    <MudRadio Value="@("none")" Color="Color.Primary" Dense="true">None</MudRadio>
                                </MudRadioGroup>
                            </MudItem>
                            @if (sysAdminModel.DatabaseNameType == "new")
                            {
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="sysAdminModel.DatabaseName" Label="Database Name" Variant="Variant.Outlined"
                                        Placeholder="@($"{request.ApplicationName}-db")" HelperText="Leave blank to auto-generate (e.g. appname-db)" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="sysAdminModel.DatabaseUsername" Label="Database Username" Variant="Variant.Outlined"
                                        Placeholder="@($"{request.ApplicationName}-user")" HelperText="Leave blank to auto-generate" />
                                </MudItem>
                            }
                            @if (sysAdminModel.DatabaseNameType == "existing")
                            {
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="sysAdminModel.DatabaseName" Label="Existing Database Name" Variant="Variant.Outlined" Required="true"
                                        HelperText="Enter the name of the existing database" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="sysAdminModel.DatabaseUsername" Label="Database Username" Variant="Variant.Outlined"
                                        HelperText="Enter the existing database username" />
                                </MudItem>
                            }
                            <MudItem xs="12" sm="6">
                                <MudSelect @bind-Value="sysAdminModel.ResourceGroupId" Label="Resource Group" Variant="Variant.Outlined" T="Guid?" Clearable="true">
                                    @foreach (var rg in resourceGroups)
                                    {
                                        <MudSelectItem Value="@((Guid?)rg.ResourceGroupId)">@rg.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            @if (sysAdminModel.ResourceGroupId != null)
                            {
                                var rg = resourceGroups.FirstOrDefault(r => r.ResourceGroupId == sysAdminModel.ResourceGroupId);
                                @if (rg != null)
                                {
                                    <MudItem xs="12">
                                        <MudAlert Severity="Severity.Info" Dense="true" Style="border-radius: 10px;">
                                            @($"{rg.VCpu} vCPU, {rg.Ram} RAM, {rg.Hdd} HDD")
                                        </MudAlert>
                                    </MudItem>
                                }
                            }
                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle1" Class="mt-2 mb-2" Style="font-weight: 600;">Services</MudText>
                                @for (int i = 0; i < sysAdminModel.Services.Count; i++)
                                {
                                    var idx = i;
                                    <MudGrid Class="mb-1">
                                        <MudItem xs="3">
                                            <MudTextField @bind-Value="sysAdminModel.Services[idx].Port" Label="Port" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="e.g. 443" />
                                        </MudItem>
                                        <MudItem xs="3">
                                            <MudSelect @bind-Value="sysAdminModel.Services[idx].Protocol" Label="Protocol" Variant="Variant.Outlined" Margin="Margin.Dense" T="string">
                                                <MudSelectItem Value="@("TCP")">TCP</MudSelectItem>
                                                <MudSelectItem Value="@("UDP")">UDP</MudSelectItem>
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudTextField @bind-Value="sysAdminModel.Services[idx].ServiceName" Label="Service Name" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="e.g. HTTPS" />
                                        </MudItem>
                                        <MudItem xs="2" Class="d-flex align-center">
                                            <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline" Color="Color.Error" Size="Size.Small"
                                                OnClick="@(() => sysAdminModel.Services.RemoveAt(idx))" />
                                        </MudItem>
                                    </MudGrid>
                                }
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add"
                                    OnClick="@(() => sysAdminModel.Services.Add(new()))" Style="text-transform: none;">
                                    Add Service
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                        </MudForm>
                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="HandleSaveSysAdmin" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Save">
                                Save
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleSubmitSysAdmin" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Publish">
                                @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                Submit
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Dark" OnClick="ToggleInlineSendBack" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Undo">
                                Send Back
                            </MudButton>
                        </MudStack>
                        @if (showInlineSendBack)
                        {
                            <MudPaper id="send-back-panel" Elevation="0" Class="pa-3 mt-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px;">
                                <MudTextField @bind-Value="sendBackComments" Label="Reason for sending back (required)" Required="true"
                                    Lines="2" Variant="Variant.Outlined" Class="mb-3" Immediate="true" />
                                <MudStack Row="true" Spacing="2">
                                    <MudButton Variant="@(string.IsNullOrWhiteSpace(sendBackComments) ? Variant.Outlined : Variant.Filled)"
                                        Color="Color.Dark" OnClick="HandleSendBack"
                                        Disabled="@(isBusy || string.IsNullOrWhiteSpace(sendBackComments))"
                                        Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Undo">
                                        @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                        Confirm Send Back
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" OnClick="@(() => showInlineSendBack = false)"
                                        Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudPaper>
                }

                @* SysAdmin Details (read-only) *@
                @if (CanSeeSection(1) && request.SysAdminDetails != null && request.Status != "PendingSysAdmin")
                {
                    <MudPaper Elevation="0" Class="section-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #43e97b, #38f9d7);">
                                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="color: white;" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">SysAdmin Details</MudText>
                        </MudStack>
                        <MudSimpleTable Dense="true" Hover="true" Style="border-radius: 12px;">
                            <tbody>
                                <tr><td style="width:200px"><strong>Sensitivity</strong></td><td>@request.SysAdminDetails.SensitivityLevel</td></tr>
                                <tr><td><strong>Web Server</strong></td><td>@request.SysAdminDetails.WebServer</td></tr>
                                <tr><td><strong>Hostname</strong></td><td>@request.SysAdminDetails.Hostname</td></tr>
                                <tr><td><strong>Database</strong></td><td>@(request.SysAdminDetails.DatabaseNameType == "none" ? "None" : request.SysAdminDetails.DatabaseNameType == "new" ? "New Database" : "Existing Database")</td></tr>
                                @if (request.SysAdminDetails.DatabaseNameType != "none")
                                {
                                    <tr><td><strong>Database Name</strong></td><td>@request.SysAdminDetails.DatabaseName</td></tr>
                                    <tr><td><strong>Database Username</strong></td><td>@request.SysAdminDetails.DatabaseUsername</td></tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                }

                @* DataCenter Form *@
                @if (CanSeeSection(2) && request.Status == "DataCenterReview")
                {
                    <MudPaper Elevation="0" Class="section-card action-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                        @if (WasSentBack && _userRole is "DataCenter" or "PlatformAdmin")
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3" Icon="@Icons.Material.Filled.Replay" Dense="true">
                                Request was sent back — please review, update if needed, and re-submit.
                            </MudAlert>
                        }
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #f093fb, #f5576c);">
                                <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" Style="color: white;" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">DataCenter Details</MudText>
                        </MudStack>
                        <MudForm @ref="dcForm">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudSelect @bind-Value="dcModel.Environment" Label="Server Environment" Variant="Variant.Outlined" Required="true" RequiredError="Server Environment is required.">
                                    @foreach (var opt in _serverEnvironments)
                                    {
                                        <MudSelectItem Value="@opt.Value">@opt.Value</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="dcModel.UplinkSpeed" Label="Uplink Speed" Variant="Variant.Outlined" Placeholder="e.g. 10Gbps" Required="true" RequiredError="Uplink Speed is required." Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect @bind-Value="dcModel.BareMetalType" Label="Bare Metal Type" Variant="Variant.Outlined" Required="true" RequiredError="Bare Metal Type is required.">
                                    @foreach (var opt in _bareMetalTypes)
                                    {
                                        <MudSelectItem Value="@opt.Value">@opt.Value</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="dcModel.PortNumber" Label="Port Number" Variant="Variant.Outlined" Required="true" RequiredError="Port Number is required." Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="dcModel.DC" Label="DC" Variant="Variant.Outlined" Required="true" RequiredError="DC is required." Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="dcModel.RackRoom" Label="Rack Row" Variant="Variant.Outlined" Required="true" RequiredError="Rack Row is required." Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="dcModel.RackNumber" Label="Rack Number" Variant="Variant.Outlined" Required="true" RequiredError="Rack Number is required." Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect @bind-Value="dcModel.Cluster" Label="Cluster" Variant="Variant.Outlined" Required="true" RequiredError="Cluster is required.">
                                    @foreach (var opt in _clusters)
                                    {
                                        <MudSelectItem Value="@opt.Value">@opt.Value</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                        </MudForm>
                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="HandleSaveDC" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Save">
                                Save
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleSubmitDC" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Publish">
                                @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                Submit
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Dark" OnClick="ToggleInlineSendBack" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Undo">
                                Send Back
                            </MudButton>
                        </MudStack>
                        @if (showInlineSendBack)
                        {
                            <MudPaper id="send-back-panel" Elevation="0" Class="pa-3 mt-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px;">
                                <MudTextField @bind-Value="sendBackComments" Label="Reason for sending back (required)" Required="true"
                                    Lines="2" Variant="Variant.Outlined" Class="mb-3" Immediate="true" />
                                <MudStack Row="true" Spacing="2">
                                    <MudButton Variant="@(string.IsNullOrWhiteSpace(sendBackComments) ? Variant.Outlined : Variant.Filled)"
                                        Color="Color.Dark" OnClick="HandleSendBack"
                                        Disabled="@(isBusy || string.IsNullOrWhiteSpace(sendBackComments))"
                                        Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Undo">
                                        @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                        Confirm Send Back
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" OnClick="@(() => showInlineSendBack = false)"
                                        Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudPaper>
                }

                @* DataCenter Details (read-only) *@
                @if (CanSeeSection(2) && request.DataCenterDetails != null && request.Status != "DataCenterReview")
                {
                    <MudPaper Elevation="0" Class="section-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #43e97b, #38f9d7);">
                                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="color: white;" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">DataCenter Details</MudText>
                        </MudStack>
                        <MudSimpleTable Dense="true" Hover="true" Style="border-radius: 12px;">
                            <tbody>
                                <tr><td style="width:200px"><strong>Environment</strong></td><td>@request.DataCenterDetails.Environment</td></tr>
                                <tr><td><strong>Uplink Speed</strong></td><td>@request.DataCenterDetails.UplinkSpeed</td></tr>
                                <tr><td><strong>Bare Metal Type</strong></td><td>@request.DataCenterDetails.BareMetalType</td></tr>
                                <tr><td><strong>Port Number</strong></td><td>@request.DataCenterDetails.PortNumber</td></tr>
                                <tr><td><strong>DC</strong></td><td>@request.DataCenterDetails.DC</td></tr>
                                <tr><td><strong>Rack Row</strong></td><td>@request.DataCenterDetails.RackRoom</td></tr>
                                <tr><td><strong>Rack Number</strong></td><td>@request.DataCenterDetails.RackNumber</td></tr>
                                <tr><td><strong>Cluster</strong></td><td>@request.DataCenterDetails.Cluster</td></tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                }

                @* NOC Form (NOC + IOC+ only) *@
                @if (CanSeeNOC && !WasSentBack && request.Status is "PendingNOC" or "PendingSOC" && (!nocSaved || isEditingNOC))
                {
                    <MudPaper Elevation="0" Class="section-card action-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #ffa726, #ff7043);">
                                <MudIcon Icon="@Icons.Material.Filled.Router" Size="Size.Small" Style="color: white;" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">NOC Details</MudText>
                        </MudStack>
                        <MudForm @ref="nocForm">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="nocModel.IPAddress" Label="Real IP Address" Variant="Variant.Outlined" Required="true" RequiredError="This field is required." Validation="@(new Func<string, string?>(IPAddressValidator))" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="nocModel.SubnetMask" Label="Real Subnet Mask" Variant="Variant.Outlined" Required="true" RequiredError="This field is required." Validation="@(new Func<string, string?>(SubnetMaskValidator))" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="nocModel.VLANID" Label="Real VLAN ID" Variant="Variant.Outlined" Required="true" RequiredError="VLAN ID is required." Validation="@(new Func<string, string?>(VLANValidator))" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="nocModel.Gateway" Label="Real Gateway" Variant="Variant.Outlined" Validation="@(new Func<string, string?>(OptionalIPValidator))" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="nocModel.Port" Label="Uplink Port" Variant="Variant.Outlined" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="nocModel.VIP" Label="VIP (Virtual IP)" Variant="Variant.Outlined" Validation="@(new Func<string, string?>(OptionalIPValidator))" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="nocModel.FQDN" Label="FQDN" Variant="Variant.Outlined" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="nocModel.VirtualPort" Label="Virtual Port" Variant="Variant.Outlined" Validation="@(new Func<string, string?>(OptionalPortValidator))" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="nocModel.VirtualFQDN" Label="Virtual FQDN" Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                        </MudForm>
                        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2" Style="font-weight: 600;">Network Paths</MudText>
                        @for (int i = 0; i < nocModel.NetworkPaths.Count; i++)
                        {
                            var idx = i;
                            <MudGrid Class="mb-2">
                                <MudItem xs="4">
                                    <MudTextField @bind-Value="nocModel.NetworkPaths[idx].SwitchName" Label="Device Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="3">
                                    <MudTextField @bind-Value="nocModel.NetworkPaths[idx].Port" Label="Port" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="3">
                                    <MudTextField @bind-Value="nocModel.NetworkPaths[idx].LinkSpeed" Label="Link Speed" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="2" Class="d-flex align-center">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                        OnClick="@(() => nocModel.NetworkPaths.RemoveAt(idx))" />
                                </MudItem>
                            </MudGrid>
                        }
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-2">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add"
                                OnClick="@(() => nocModel.NetworkPaths.Add(new()))" Style="border-radius: 10px; text-transform: none;">
                                Add Network Path
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="HandleSaveNOC" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Save">
                                @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                Save NOC Details
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => showNocReject = !showNocReject)" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Undo">
                                Send Back to DataCenter
                            </MudButton>
                        </MudStack>
                        @if (showNocReject)
                        {
                            <MudPaper Elevation="0" Class="pa-3 mt-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;">
                                <MudTextField @bind-Value="nocRejectReason" Label="Reason for sending back (required)" Required="true"
                                    Lines="3" Variant="Variant.Outlined" Class="mb-2" />
                                <MudStack Row="true" Spacing="2">
                                    <MudButton Variant="Variant.Filled" Color="Color.Error"
                                        Disabled="@(isBusy || string.IsNullOrWhiteSpace(nocRejectReason))"
                                        OnClick="HandleNOCSendBack" Style="border-radius: 12px; text-transform: none;"
                                        StartIcon="@Icons.Material.Filled.Undo">
                                        Confirm & Send Back
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" OnClick="@(() => showNocReject = false)"
                                        Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudPaper>
                }

                @* NOC Details (read-only, NOC + IOC+ only) *@
                @if (CanSeeNOC && request.NOCDetails != null && (request.Status is not ("PendingNOC" or "PendingSOC") || (nocSaved && !isEditingNOC)))
                {
                    <MudPaper Elevation="0" Class="section-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                        @if (WasSentBack && request.Status is "PendingNOC" or "PendingSOC")
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3" Icon="@Icons.Material.Filled.Visibility" Dense="true">
                                Request was sent back — view only.
                            </MudAlert>
                        }
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #43e97b, #38f9d7);">
                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="color: white;" />
                                </MudAvatar>
                                <MudText Typo="Typo.h6">NOC Details</MudText>
                            </MudStack>
                            @if (!WasSentBack && request.Status is "PendingNOC" or "PendingSOC" && _userRole is "NOC" or "PlatformAdmin")
                            {
                                <MudStack Row="true" Spacing="2">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Send" Style="border-radius: 10px; text-transform: none;"
                                               Disabled="@isBusy" OnClick="HandleSubmitNOC">
                                        Submit
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Edit" Style="border-radius: 10px; text-transform: none;"
                                               OnClick="@(() => isEditingNOC = true)">
                                        Edit
                                    </MudButton>
                                </MudStack>
                            }
                        </MudStack>
                        <MudSimpleTable Dense="true" Hover="true" Style="border-radius: 12px;">
                            <tbody>
                                <tr><td style="width:200px"><strong>Real IP Address</strong></td><td>@request.NOCDetails.IPAddress</td></tr>
                                <tr><td><strong>Real Subnet Mask</strong></td><td>@request.NOCDetails.SubnetMask</td></tr>
                                <tr><td><strong>Real VLAN ID</strong></td><td>@request.NOCDetails.VLANID</td></tr>
                                <tr><td><strong>Real Gateway</strong></td><td>@request.NOCDetails.Gateway</td></tr>
                                <tr><td><strong>Uplink Port</strong></td><td>@request.NOCDetails.Port</td></tr>
                                <tr><td><strong>VIP (Virtual IP)</strong></td><td>@request.NOCDetails.VIP</td></tr>
                                <tr><td><strong>FQDN</strong></td><td>@request.NOCDetails.FQDN</td></tr>
                                <tr><td><strong>Virtual Port</strong></td><td>@request.NOCDetails.VirtualPort</td></tr>
                                <tr><td><strong>Virtual FQDN</strong></td><td>@request.NOCDetails.VirtualFQDN</td></tr>
                            </tbody>
                        </MudSimpleTable>
                        @if (request.NOCDetails.NetworkPaths.Any())
                        {
                            <MudText Typo="Typo.subtitle2" Class="mt-3 mb-2" Style="font-weight: 600;">Network Paths</MudText>
                            <MudSimpleTable Dense="true" Hover="true" Style="border-radius: 12px;">
                                <thead><tr><th>Device Name</th><th>Port</th><th>Link Speed</th></tr></thead>
                                <tbody>
                                    @foreach (var np in request.NOCDetails.NetworkPaths)
                                    {
                                        <tr><td>@np.SwitchName</td><td>@np.Port</td><td>@np.LinkSpeed</td></tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                    </MudPaper>
                }

                @* SOC Form (SOC + IOC+ only) *@
                @if (CanSeeSOC && !WasSentBack && request.Status is "PendingNOC" or "PendingSOC" && (!socSaved || isEditingSOC))
                {
                    <MudPaper Elevation="0" Class="section-card action-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #ef5350, #d32f2f);">
                                <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Small" Style="color: white;" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">SOC Details — Firewall Entries</MudText>
                        </MudStack>
                        @for (int i = 0; i < socModel.FirewallEntries.Count; i++)
                        {
                            var idx = i;
                            <MudPaper Elevation="0" Class="pa-3 mb-3" Style="border: 1px dashed var(--mud-palette-lines-default); border-radius: 8px;">
                                <MudGrid>
                                    <MudItem xs="6">
                                        <MudTextField @bind-Value="socModel.FirewallEntries[idx].PolicyName" Label="Policy Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudSelect @bind-Value="socModel.FirewallEntries[idx].VDOM" Label="VDOM" Variant="Variant.Outlined" Margin="Margin.Dense" T="string">
                                            @foreach (var v in vdoms)
                                            {
                                                <MudSelectItem Value="@v.Name">@v.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudTextField @bind-Value="socModel.FirewallEntries[idx].SourceInterface" Label="Source Interface" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudTextField @bind-Value="socModel.FirewallEntries[idx].DestinationInterface" Label="Destination Interface" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudTextField @bind-Value="socModel.FirewallEntries[idx].SourceIP" Label="Source IP" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudTextField @bind-Value="socModel.FirewallEntries[idx].DestinationIP" Label="Destination IP" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="4">
                                        <MudTextField @bind-Value="socModel.FirewallEntries[idx].Schedule" Label="Schedule" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="e.g. 2026-03-05" InputType="InputType.Date" />
                                    </MudItem>
                                    <MudItem xs="4">
                                    </MudItem>

                                    @* Security Profiles (multi-select from admin list) *@
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.subtitle2" Class="mb-1" Style="font-weight: 600;">Security Profiles</MudText>
                                        @if (securityProfiles.Any())
                                        {
                                            var feIdx2 = idx;
                                            @foreach (var sp in securityProfiles)
                                            {
                                                var isSelected = socModel.FirewallEntries[feIdx2].SecurityProfileNames.Contains(sp.Name);
                                                <MudCheckBox T="bool" Value="@isSelected" Label="@sp.Name" Dense="true"
                                                    ValueChanged="@((bool val) => ToggleSecurityProfile(feIdx2, sp.Name, val))" />
                                            }
                                        }
                                        else
                                        {
                                            <MudAlert Severity="Severity.Info" Dense="true" Style="border-radius: 8px;">
                                                No security profiles defined. Add them in Admin Settings.
                                            </MudAlert>
                                        }
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add"
                            OnClick="@(() => socModel.FirewallEntries.Add(new()))" Style="border-radius: 10px; text-transform: none;">
                            Add Firewall Entry
                        </MudButton>
                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="HandleSaveSOC" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Save">
                                @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                Save SOC Details
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => showSocReject = !showSocReject)" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Undo">
                                Send Back
                            </MudButton>
                        </MudStack>
                        @if (showSocReject)
                        {
                            <MudPaper Elevation="0" Class="pa-3 mt-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;">
                                <MudTextField @bind-Value="socRejectReason" Label="Reason for sending back (required)" Required="true"
                                    Lines="3" Variant="Variant.Outlined" Class="mb-2" />
                                <MudStack Row="true" Spacing="2">
                                    <MudButton Variant="Variant.Filled" Color="Color.Error"
                                        Disabled="@(isBusy || string.IsNullOrWhiteSpace(socRejectReason))"
                                        OnClick="HandleSOCSendBack" Style="border-radius: 12px; text-transform: none;"
                                        StartIcon="@Icons.Material.Filled.Undo">
                                        Confirm & Send Back
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" OnClick="@(() => showSocReject = false)"
                                        Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudPaper>
                }

                @* SOC Details (read-only, SOC + IOC+ only) *@
                @if (CanSeeSOC && request.SOCDetails != null && (request.Status is not ("PendingNOC" or "PendingSOC") || (socSaved && !isEditingSOC)))
                {
                    <MudPaper Elevation="0" Class="section-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                        @if (WasSentBack && request.Status is "PendingNOC" or "PendingSOC")
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3" Icon="@Icons.Material.Filled.Visibility" Dense="true">
                                Request was sent back — view only.
                            </MudAlert>
                        }
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #43e97b, #38f9d7);">
                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="color: white;" />
                                </MudAvatar>
                                <MudText Typo="Typo.h6">SOC Details</MudText>
                            </MudStack>
                            @if (!WasSentBack && request.Status is "PendingNOC" or "PendingSOC" && _userRole is "SOC" or "PlatformAdmin")
                            {
                                <MudStack Row="true" Spacing="2">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Send" Style="border-radius: 10px; text-transform: none;"
                                               Disabled="@isBusy" OnClick="HandleSubmitSOC">
                                        Submit
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Edit" Style="border-radius: 10px; text-transform: none;"
                                               OnClick="@(() => isEditingSOC = true)">
                                        Edit
                                    </MudButton>
                                </MudStack>
                            }
                        </MudStack>
                        @if (request.SOCDetails.FirewallEntries.Any())
                        {
                            <MudSimpleTable Dense="true" Hover="true" Style="border-radius: 12px;">
                                <thead><tr><th>Policy Name</th><th>VDOM</th><th>Src Interface</th><th>Dst Interface</th><th>Src IP</th><th>Dst IP</th><th>Schedule</th><th>Security Profiles</th></tr></thead>
                                <tbody>
                                    @foreach (var fe in request.SOCDetails.FirewallEntries)
                                    {
                                        <tr>
                                            <td>@fe.PolicyName</td>
                                            <td>@fe.VDOM</td>
                                            <td>@fe.SourceInterface</td>
                                            <td>@fe.DestinationInterface</td>
                                            <td>@fe.SourceIP</td>
                                            <td>@fe.DestinationIP</td>
                                            <td>@fe.Schedule</td>
                                            <td>
                                                @if (fe.SecurityProfileNames.Any())
                                                {
                                                    @string.Join(", ", fe.SecurityProfileNames)
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">No firewall entries.</MudText>
                        }
                        @if (!WasSentBack && request.Status is "PendingNOC" or "PendingSOC" && _userRole is "SOC" or "PlatformAdmin")
                        {
                            <MudStack Row="true" Spacing="2" Class="mt-3">
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => showSocReject = !showSocReject)" Disabled="@isBusy"
                                           Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Undo">
                                    Send Back
                                </MudButton>
                            </MudStack>
                            @if (showSocReject)
                            {
                                <MudPaper Elevation="0" Class="pa-3 mt-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;">
                                    <MudTextField @bind-Value="socRejectReason" Label="Reason for sending back (required)" Required="true"
                                        Lines="3" Variant="Variant.Outlined" Class="mb-2" />
                                    <MudStack Row="true" Spacing="2">
                                        <MudButton Variant="Variant.Filled" Color="Color.Error"
                                            Disabled="@(isBusy || string.IsNullOrWhiteSpace(socRejectReason))"
                                            OnClick="HandleSOCSendBack" Style="border-radius: 12px; text-transform: none;"
                                            StartIcon="@Icons.Material.Filled.Undo">
                                            Confirm & Send Back
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined" OnClick="@(() => showSocReject = false)"
                                            Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
                                    </MudStack>
                                </MudPaper>
                            }
                        }
                    </MudPaper>
                }

                @* IOC Manager — Publish NOC/SOC submissions *@
                @if (CanSeeSection(4) && !WasSentBack && request.Status is "PendingNOC" or "PendingSOC" && (request.NOCDetails != null || request.SOCDetails != null))
                {
                    <MudPaper Elevation="0" Class="section-card action-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #667eea, #764ba2);">
                                <MudIcon Icon="@Icons.Material.Filled.Gavel" Size="Size.Small" Style="color: white;" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">IOC Manager — Review & Publish</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
                            Review saved NOC/SOC data below. Publish when both are ready to advance to IOC Approval.
                        </MudText>
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudChip T="string" Size="Size.Small" Color="@(request.NOCDetails != null ? Color.Success : Color.Default)" Variant="Variant.Filled" Style="border-radius: 8px;">
                                NOC: @(request.NOCDetails != null ? "Saved" : "Pending")
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Color="@(request.SOCDetails != null ? Color.Success : Color.Default)" Variant="Variant.Filled" Style="border-radius: 8px;">
                                SOC: @(request.SOCDetails != null ? "Saved" : "Pending")
                            </MudChip>
                        </MudStack>
                        @if (request.NOCDetails != null && request.SOCDetails != null)
                        {
                            <MudTextField @bind-Value="approvalComments" Label="IOC Comments (optional)" Lines="2" Variant="Variant.Outlined" Class="mb-3" />
                            <MudStack Row="true" Spacing="2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleIOCPublish" Disabled="@isBusy"
                                           Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Publish">
                                    @if (isBusy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                    Publish NOC & SOC
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Dark" OnClick="ToggleIocSendBack" Disabled="@isBusy"
                                           Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Undo">
                                    Send Back
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => showIocReject = !showIocReject)" Disabled="@isBusy"
                                           Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Cancel">
                                    Reject
                                </MudButton>
                            </MudStack>
                            @if (showIocSendBack)
                            {
                                <MudPaper id="ioc-send-back-panel" Elevation="0" Class="pa-3 mt-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;">
                                    <MudSelect T="string" @bind-Value="iocSendBackTarget" Label="Send back to" Variant="Variant.Outlined" Class="mb-2" Required="true">
                                        <MudSelectItem T="string" Value="@("PendingNOC")">NOC</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("PendingSOC")">SOC</MudSelectItem>
                                    </MudSelect>
                                    <MudTextField @bind-Value="iocSendBackComments" Label="Reason for sending back (required)" Required="true"
                                        Lines="3" Variant="Variant.Outlined" Class="mb-2" />
                                    <MudStack Row="true" Spacing="2">
                                        <MudButton Variant="@(string.IsNullOrWhiteSpace(iocSendBackComments) || string.IsNullOrWhiteSpace(iocSendBackTarget) ? Variant.Outlined : Variant.Filled)"
                                            Color="Color.Dark" OnClick="HandleIOCSendBack"
                                            Disabled="@(isBusy || string.IsNullOrWhiteSpace(iocSendBackComments) || string.IsNullOrWhiteSpace(iocSendBackTarget))"
                                            Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Undo">
                                            Confirm Send Back
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined" OnClick="@(() => showIocSendBack = false)"
                                            Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
                                    </MudStack>
                                </MudPaper>
                            }
                            @if (showIocReject)
                            {
                                <MudPaper Elevation="0" Class="pa-3 mt-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;">
                                    <MudTextField @bind-Value="iocRejectReason" Label="Reason for rejection (required)" Required="true"
                                        Lines="3" Variant="Variant.Outlined" Class="mb-2" />
                                    <MudStack Row="true" Spacing="2">
                                        <MudButton Variant="Variant.Filled" Color="Color.Error"
                                            Disabled="@(isBusy || string.IsNullOrWhiteSpace(iocRejectReason))"
                                            OnClick="HandleIOCReject" Style="border-radius: 12px; text-transform: none;"
                                            StartIcon="@Icons.Material.Filled.Cancel">
                                            Confirm Rejection
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined" OnClick="@(() => showIocReject = false)"
                                            Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
                                    </MudStack>
                                </MudPaper>
                            }
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Style="border-radius: 10px;">
                                Both NOC and SOC must save their details before publishing.
                            </MudAlert>
                        }
                    </MudPaper>
                }

                @* IOC Manager Approval *@
                @if (CanSeeSection(4) && request.Status == "PendingIOCApproval")
                {
                    <MudPaper Elevation="0" Class="section-card action-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #764ba2, #667eea);">
                                <MudIcon Icon="@Icons.Material.Filled.Approval" Size="Size.Small" Style="color: white;" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">IOC Manager Approval</MudText>
                        </MudStack>
                        @if (!showIocSendBack && !showIocReject)
                        {
                            <MudTextField @bind-Value="approvalComments" Label="Comments" Lines="3" Variant="Variant.Outlined" Class="mb-3" />
                        }
                        <MudStack Row="true" Spacing="2">
                            @if (!showIocSendBack && !showIocReject)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="HandleIOCApproval" Disabled="@isBusy"
                                           Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.CheckCircle">
                                    Approve & Forward
                                </MudButton>
                            }
                            <MudButton Variant="Variant.Outlined" Color="@(showIocSendBack ? Color.Primary : Color.Dark)" OnClick="ToggleIocSendBack" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Undo">
                                Send Back
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="@(showIocReject ? Color.Primary : Color.Error)" OnClick="ToggleIocReject" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Cancel">
                                Reject
                            </MudButton>
                        </MudStack>
                        @if (showIocSendBack)
                        {
                            <MudPaper id="ioc-send-back-panel" Elevation="0" Class="pa-3 mt-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;">
                                <MudSelect T="string" @bind-Value="iocSendBackTarget" Label="Send back to" Variant="Variant.Outlined" Class="mb-2" Required="true">
                                    <MudSelectItem T="string" Value="@("PendingNOC")">NOC</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("PendingSOC")">SOC</MudSelectItem>
                                </MudSelect>
                                <MudTextField @bind-Value="iocSendBackComments" Label="Reason for sending back (required)" Required="true"
                                    Lines="3" Variant="Variant.Outlined" Class="mb-2" />
                                <MudStack Row="true" Spacing="2">
                                    <MudButton Variant="@(string.IsNullOrWhiteSpace(iocSendBackComments) || string.IsNullOrWhiteSpace(iocSendBackTarget) ? Variant.Outlined : Variant.Filled)"
                                        Color="Color.Dark" OnClick="HandleIOCSendBack"
                                        Disabled="@(isBusy || string.IsNullOrWhiteSpace(iocSendBackComments) || string.IsNullOrWhiteSpace(iocSendBackTarget))"
                                        Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Undo">
                                        Confirm Send Back
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" OnClick="@(() => showIocSendBack = false)"
                                        Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
                                </MudStack>
                            </MudPaper>
                        }
                        @if (showIocReject)
                        {
                            <MudPaper id="ioc-reject-panel" Elevation="0" Class="pa-3 mt-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;">
                                <MudTextField @bind-Value="iocRejectReason" Label="Reason for rejection (required)" Required="true"
                                    Lines="3" Variant="Variant.Outlined" Class="mb-2" />
                                <MudStack Row="true" Spacing="2">
                                    <MudButton Variant="@(string.IsNullOrWhiteSpace(iocRejectReason) ? Variant.Outlined : Variant.Filled)" Color="Color.Error"
                                        Disabled="@(isBusy || string.IsNullOrWhiteSpace(iocRejectReason))"
                                        OnClick="HandleIOCReject" Style="border-radius: 12px; text-transform: none; font-weight: 600;"
                                        StartIcon="@Icons.Material.Filled.Cancel">
                                        Confirm Rejection
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" OnClick="@(() => showIocReject = false)"
                                        Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudPaper>
                }

                @* Approval Summary (collapsible) — visible for CISO/CTO/Ops approval *@
                @if (CanSeeSection(5) && (request.Status == "PendingApproval" || request.Status == "Approved"))
                {
                    <MudExpansionPanels Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px;">
                        <MudExpansionPanel Style="border-radius: 12px;">
                            <TitleContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.Summarize" Color="Color.Primary" />
                                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Approval Summary</MudText>
                                </MudStack>
                            </TitleContent>
                            <ChildContent>
                                <MudGrid>
                                    @* App Info *@
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-2">Application Info</MudText>
                                        <MudSimpleTable Dense="true" Bordered="true" Style="border-radius: 8px;">
                                            <tbody>
                                                <tr><td><strong>Application</strong></td><td>@request.ApplicationName</td></tr>
                                                <tr><td><strong>Environment</strong></td><td>@request.Environment</td></tr>
                                                <tr><td><strong>Slug</strong></td><td>@request.ObjectSlug</td></tr>
                                                <tr><td><strong>Language/Framework</strong></td><td>@(request.ProgrammingLanguage ?? "—") / @(request.Framework ?? "—")</td></tr>
                                                <tr><td><strong>DBMS</strong></td><td>@(request.DBMS ?? "—")</td></tr>
                                                <tr><td><strong>Expected Concurrent User Count</strong></td><td>@(request.ExpectedUsers?.ToString() ?? "—")</td></tr>
                                                <tr><td><strong>Created By</strong></td><td>@request.CreatedBy</td></tr>
                                            </tbody>
                                        </MudSimpleTable>
                                    </MudItem>

                                    @* SysAdmin *@
                                    @if (request.SysAdminDetails != null)
                                    {
                                        <MudItem xs="12" sm="6">
                                            <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-2">SysAdmin Details</MudText>
                                            <MudSimpleTable Dense="true" Bordered="true" Style="border-radius: 8px;">
                                                <tbody>
                                                    <tr><td><strong>Sensitivity</strong></td><td>@request.SysAdminDetails.SensitivityLevel</td></tr>
                                                    <tr><td><strong>Web Server</strong></td><td>@request.SysAdminDetails.WebServer</td></tr>
                                                    <tr><td><strong>Hostname</strong></td><td>@request.SysAdminDetails.Hostname</td></tr>
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudItem>
                                    }

                                    @* DataCenter *@
                                    @if (request.DataCenterDetails != null)
                                    {
                                        <MudItem xs="12" sm="6">
                                            <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-2">Data Center Details</MudText>
                                            <MudSimpleTable Dense="true" Bordered="true" Style="border-radius: 8px;">
                                                <tbody>
                                                    <tr><td><strong>DC</strong></td><td>@request.DataCenterDetails.DC</td></tr>
                                                    <tr><td><strong>Rack</strong></td><td>@request.DataCenterDetails.RackRoom / @request.DataCenterDetails.RackNumber</td></tr>
                                                    <tr><td><strong>Cluster</strong></td><td>@request.DataCenterDetails.Cluster</td></tr>
                                                    <tr><td><strong>Uplink</strong></td><td>@request.DataCenterDetails.UplinkSpeed</td></tr>
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudItem>
                                    }

                                    @* NOC *@
                                    @if (request.NOCDetails != null)
                                    {
                                        <MudItem xs="12" sm="6">
                                            <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-2">NOC Details</MudText>
                                            <MudSimpleTable Dense="true" Bordered="true" Style="border-radius: 8px;">
                                                <tbody>
                                                    <tr><td><strong>IP</strong></td><td>@request.NOCDetails.IPAddress</td></tr>
                                                    <tr><td><strong>Subnet</strong></td><td>@request.NOCDetails.SubnetMask</td></tr>
                                                    <tr><td><strong>VLAN</strong></td><td>@request.NOCDetails.VLANID</td></tr>
                                                    <tr><td><strong>FQDN</strong></td><td>@request.NOCDetails.FQDN</td></tr>
                                                    <tr><td><strong>Gateway</strong></td><td>@request.NOCDetails.Gateway</td></tr>
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudItem>
                                    }

                                    @* SOC *@
                                    @if (request.SOCDetails != null)
                                    {
                                        <MudItem xs="12" sm="6">
                                            <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-2">SOC Details</MudText>
                                            <MudSimpleTable Dense="true" Bordered="true" Style="border-radius: 8px;">
                                                <tbody>
                                                    <tr><td><strong>Firewall Entries</strong></td><td>@(request.SOCDetails.FirewallEntries?.Count ?? 0) policies</td></tr>
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudItem>
                                    }

                                    @* IOC Comments *@
                                    @if (!string.IsNullOrEmpty(request.IocComments))
                                    {
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-2">IOC Comments</MudText>
                                            <MudAlert Severity="Severity.Info" Dense="true" Style="border-radius: 10px;">@request.IocComments</MudAlert>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </ChildContent>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }

                @* Approval Status Summary *@
                @if (CanSeeSection(5) && request.Status == "PendingApproval")
                {
                    <MudPaper Elevation="0" Class="pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #f093fb, #764ba2);">
                                <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" Style="color: white;" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">Approval Status</MudText>
                        </MudStack>
                        <MudGrid>
                            <MudItem xs="6">
                                <MudChip T="string" Color="@(request.CisoDecision == "Approved" ? Color.Success : request.CisoDecision == "Rejected" ? Color.Error : Color.Warning)"
                                         Icon="@Icons.Material.Filled.Shield" Style="font-weight: 600;">
                                    CISO: @(request.CisoDecision ?? "Pending")
                                </MudChip>
                            </MudItem>
                            <MudItem xs="6">
                                <MudChip T="string" Color="@(request.OpsDecision == "Approved" ? Color.Success : request.OpsDecision == "Rejected" ? Color.Error : Color.Warning)"
                                         Icon="@Icons.Material.Filled.Build" Style="font-weight: 600;">
                                    Ops Manager: @(request.OpsDecision ?? "Pending")
                                </MudChip>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                }

                @* CISO Approval Section — only visible to CISO *@
                @if (_userRole == "CISO" && request.Status == "PendingApproval" && request.CisoDecision == null)
                {
                    <MudPaper Elevation="0" Class="section-card action-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #7c4dff, #536dfe);">
                                <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" Style="color: white;" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">CISO Review</MudText>
                        </MudStack>
                        <MudTextField @bind-Value="cisoComments" Label="CISO Comments" Lines="3" Variant="Variant.Outlined" Class="mb-3" />
                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => HandleCISOApproval("Approve"))" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.CheckCircle">
                                Approve
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => showCisoReject = !showCisoReject)" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Cancel">
                                Reject
                            </MudButton>
                        </MudStack>
                        @if (showCisoReject)
                        {
                            <MudPaper Elevation="0" Class="pa-3 mt-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;">
                                <MudTextField @bind-Value="cisoRejectReason" Label="Reason for rejection (required)" Required="true"
                                    Lines="3" Variant="Variant.Outlined" Class="mb-2" />
                                <MudStack Row="true" Spacing="2">
                                    <MudButton Variant="Variant.Filled" Color="Color.Error"
                                        Disabled="@(isBusy || string.IsNullOrWhiteSpace(cisoRejectReason))"
                                        OnClick="HandleCISOReject" Style="border-radius: 12px; text-transform: none;"
                                        StartIcon="@Icons.Material.Filled.Cancel">
                                        Confirm Rejection & Send Back
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" OnClick="@(() => showCisoReject = false)"
                                        Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudPaper>
                }

                @* Ops Manager Approval Section — only visible to Ops *@
                @if (_userRole == "Ops" && request.Status == "PendingApproval" && request.OpsDecision == null)
                {
                    <MudPaper Elevation="0" Class="section-card action-card pa-4 mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #ff6f00, #ff8f00);">
                                <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small" Style="color: white;" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">Ops Manager Review</MudText>
                        </MudStack>
                        <MudTextField @bind-Value="opsComments" Label="Ops Manager Comments" Lines="3" Variant="Variant.Outlined" Class="mb-3" />
                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => HandleOpsApproval("Approve"))" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.CheckCircle">
                                Approve
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => showOpsReject = !showOpsReject)" Disabled="@isBusy"
                                       Style="border-radius: 12px; text-transform: none;" StartIcon="@Icons.Material.Filled.Cancel">
                                Reject
                            </MudButton>
                        </MudStack>
                        @if (showOpsReject)
                        {
                            <MudPaper Elevation="0" Class="pa-3 mt-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;">
                                <MudTextField @bind-Value="opsRejectReason" Label="Reason for rejection (required)" Required="true"
                                    Lines="3" Variant="Variant.Outlined" Class="mb-2" />
                                <MudStack Row="true" Spacing="2">
                                    <MudButton Variant="Variant.Filled" Color="Color.Error"
                                        Disabled="@(isBusy || string.IsNullOrWhiteSpace(opsRejectReason))"
                                        OnClick="HandleOpsReject" Style="border-radius: 12px; text-transform: none;"
                                        StartIcon="@Icons.Material.Filled.Cancel">
                                        Confirm Rejection & Send Back
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" OnClick="@(() => showOpsReject = false)"
                                        Style="border-radius: 12px; text-transform: none;">Cancel</MudButton>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudPaper>
                }

                @* Final status banners *@
                @if (request.Status == "Approved")
                {
                    <MudAlert Severity="Severity.Success" Class="mb-4" Icon="@Icons.Material.Filled.CheckCircle" Style="border-radius: 12px;">
                        This request has been fully approved and is ready for implementation.
                    </MudAlert>
                }
                @if (request.Status == "Rejected")
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4" Icon="@Icons.Material.Filled.Cancel" Style="border-radius: 12px;">
                        This request has been rejected.
                    </MudAlert>
                }
                @if (request.Status == "Implemented")
                {
                    <MudAlert Severity="Severity.Success" Class="mb-4" Icon="@Icons.Material.Filled.RocketLaunch" Style="border-radius: 12px;">
                        This request has been implemented.
                    </MudAlert>
                }
                @if (request.Status == "Closed")
                {
                    <MudAlert Severity="Severity.Info" Class="mb-4" Icon="@Icons.Material.Filled.Lock" Style="border-radius: 12px;">
                        This request is closed.
                    </MudAlert>
                }
            </div>
        </MudItem>

        @* Right Column: Status History *@
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="premium-card pa-4" Style="border: 1px solid var(--mud-palette-lines-default); position: sticky; top: 80px;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                    <MudAvatar Size="Size.Small" Style="background: var(--gradient-primary);">
                        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Style="color: white;" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6">Status History</MudText>
                </MudStack>
                @if (request.StatusHistories.Any())
                {
                    <MudTimeline TimelinePosition="TimelinePosition.Start">
                        @foreach (var h in request.StatusHistories)
                        {
                            var isSendBack = h.Comments?.StartsWith("Sent back") == true;
                            <MudTimelineItem Color="@(isSendBack ? Color.Warning : Color.Primary)" Size="Size.Small">
                                <MudStack Spacing="0">
                                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(h.NewStatus)" Variant="Variant.Filled"
                                             Style="border-radius: 8px; font-weight: 500;">
                                        @FormatStatus(h.NewStatus)
                                    </MudChip>
                                    <MudText Typo="Typo.caption" Class="mt-1" Style="color: var(--mud-palette-text-secondary);">
                                        @h.ChangedBy &bull; @h.Timestamp.ToString("MMM dd, hh:mm tt")
                                    </MudText>
                                    @if (!string.IsNullOrEmpty(h.Comments))
                                    {
                                        <MudText Typo="Typo.body2" Class="mt-1" Style="@(isSendBack ? "color: var(--mud-palette-warning);" : "")">
                                            @h.Comments
                                        </MudText>
                                    }
                                </MudStack>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                }
                else
                {
                    <MudStack AlignItems="AlignItems.Center" Class="pa-4" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Large" Style="opacity: 0.2;" />
                        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">No history yet.</MudText>
                    </MudStack>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}
</div>

