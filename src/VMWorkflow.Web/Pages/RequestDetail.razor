            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally { isBusy = false; }
    }

    private static int GetStepIndex(string status) => status switch
    {
        "Draft" => 0, "PendingSysAdmin" => 1, "DataCenterReview" => 2,
        "PendingNOC" or "PendingSOC" => 3, "PendingIOCApproval" => 4,
        "PendingApproval" => 5, "Approved" => 6,
        "Implemented" => 8, "Closed" => 9, "Rejected" => -1, _ => -1
    };

    private bool CanSendBack(string status)
    {
        if (_userRole == "Requester") return false;
        return IsAdmin || status switch
        {
            "PendingSysAdmin" => _userRole == "SysAdmin",
            "DataCenterReview" => _userRole == "DataCenter",
            "PendingNOC" or "PendingSOC" => _userRole is "NOC" or "SOC" or "IOCManager",
            "PendingIOCApproval" => _userRole == "IOCManager",
            "PendingApproval" => _userRole is "CISO" or "Ops",
            _ => false
        };
    }

    private static string GetPulseClass(string status) => status switch
    {
        "Approved" or "Implemented" or "Closed" => "pulse-active",
        "Rejected" => "pulse-error",
        _ => "pulse-pending"
    };

    private static Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Default, "PendingSysAdmin" => Color.Info, "DataCenterReview" => Color.Info,
        "PendingNOC" => Color.Warning, "PendingSOC" => Color.Warning,
        "PendingIOCApproval" => Color.Secondary, "PendingApproval" => Color.Secondary,
        "Approved" => Color.Success, "Rejected" => Color.Error,
        "Implemented" => Color.Success, "Closed" => Color.Dark, _ => Color.Default
    };

    private static string FormatStatus(string status) => status switch
    {
        "PendingSysAdmin" => "Pending SysAdmin", "DataCenterReview" => "DC Review",
        "PendingNOC" => "Pending NOC", "PendingSOC" => "Pending SOC",
        "PendingIOCApproval" => "IOC Approval", "PendingApproval" => "Pending Approval (2 of 3)", _ => status
    };
}
