    private void ToggleSOCService(int fwIdx, ServiceEntryModel svc, bool selected)
    {
        if (fwIdx >= socModel.FirewallEntries.Count) return;
        var services = socModel.FirewallEntries[fwIdx].Services;
        if (selected)
        {
            if (!services.Any(s => s.Port == svc.Port && s.Protocol == svc.Protocol && s.ServiceName == svc.ServiceName))
                services.Add(new ServiceEntryModel { Port = svc.Port, Protocol = svc.Protocol, ServiceName = svc.ServiceName });
        }
        else
        {
            services.RemoveAll(s => s.Port == svc.Port && s.Protocol == svc.Protocol && s.ServiceName == svc.ServiceName);
        }
    }

    private void ToggleSecurityProfile(int fwIdx, string profileName, bool selected)
    {
        if (fwIdx >= socModel.FirewallEntries.Count) return;
        var names = socModel.FirewallEntries[fwIdx].SecurityProfileNames;
        if (selected)
        {
            if (!names.Contains(profileName))
                names.Add(profileName);
        }
        else
        {
            names.Remove(profileName);
        }
    }

