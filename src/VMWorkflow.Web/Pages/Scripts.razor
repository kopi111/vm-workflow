@page "/scripts"
@attribute [Authorize]
@inject IApiClient Api
@inject IJSRuntime JS

<AuthorizeView Roles="NOC,SOC,IOCManager,PlatformAdmin" Context="authContext">
    <Authorized>
        <MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 600;">Generated Scripts</MudText>

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="() => _error = null">@_error</MudAlert>
        }

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
        }
        else
        {
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px;">
                <MudTable Items="@_scripts" Dense="true" Hover="true" Striped="true" Loading="@_loading"
                          LoadingProgressColor="Color.Primary" Elevation="0">
                    <HeaderContent>
                        <MudTh>Request</MudTh>
                        <MudTh>Application</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Generated By</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh Style="text-align: center;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudLink Href="@($"/request/{context.RequestId}")" Typo="Typo.body2">@context.RequestSlug</MudLink>
                        </MudTd>
                        <MudTd>@context.ApplicationName</MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@context.ScriptType</MudChip>
                        </MudTd>
                        <MudTd>@context.GeneratedBy</MudTd>
                        <MudTd>@context.GeneratedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                        <MudTd Style="text-align: center;">
                            <MudIconButton Icon="@Icons.Material.Filled.Download" Color="Color.Primary" Size="Size.Small"
                                           OnClick="@(() => DownloadScript(context.ScriptId, context.FileName))" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Align="Align.Center" Class="pa-4" Style="color: var(--mud-palette-text-secondary);">
                            No scripts have been generated yet.
                        </MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudPaper>
        }
    </Authorized>
    <NotAuthorized>
        <MudAlert Severity="Severity.Warning">You do not have permission to view this page.</MudAlert>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<ScriptModel> _scripts = new();
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _scripts = await Api.GetScriptsAsync();
        }
        catch
        {
            _error = "Unable to load scripts. Please try again later.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DownloadScript(Guid scriptId, string fileName)
    {
        try
        {
            var bytes = await Api.DownloadScriptAsync(scriptId);
            var base64 = Convert.ToBase64String(bytes);
            var js = "var a = document.createElement('a');" +
                     "a.href = 'data:text/plain;base64," + base64 + "';" +
                     "a.download = '" + fileName + "';" +
                     "document.body.appendChild(a);" +
                     "a.click();" +
                     "document.body.removeChild(a);";
            await JS.InvokeVoidAsync("eval", js);
        }
        catch
        {
            _error = "Failed to download script. Please try again.";
            StateHasChanged();
        }
    }
}
