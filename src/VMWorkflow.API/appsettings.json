{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "LogPath": "C:\\Logs\\VMWorkflow"
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "VMWorkflow.API",
    "Audience": "VMWorkflow.Web",
    "ExpireMinutes": 480
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=VMWorkflow;Uid=vmworkflow;Pwd=Password@123;"
  },
  "ActiveDirectory": {
    "Enabled": false,
    "Domain": "yourdomain.local",
    "LdapServer": "ldap://your-dc-server.yourdomain.local",
    "LdapPort": 389,
    "SearchBase": "DC=yourdomain,DC=local",
    "UseSsl": false,
    "RoleMapping": {
      "VM-PlatformAdmins": "PlatformAdmin",
      "VM-SysAdmins": "SysAdmin",
      "VM-Requesters": "Requester",
      "VM-DataCenter": "DataCenter",
      "VM-NOC": "NOC",
      "VM-SOC": "SOC",
      "VM-IOCManagers": "IOCManager",
      "VM-CISO": "CISO",
      "VM-Ops": "Ops"
    },
    "DefaultRole": "Requester"
  }
}
